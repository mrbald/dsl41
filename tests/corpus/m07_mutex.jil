/* M07 mutex-candidate detector (dossier R6): n() atoms are NOT dependencies --
   mutex_a/mutex_b mutually exclude via n(); mutex_serial self-excludes via
   n(mutex_serial) (UC Instance Wait, UCS-09). L012 suggests the UC construct
   per group shape. mutex_feeder is a plain scheduled producer whose s() edge
   must still surface despite the sibling n() atoms. (Renamed from the
   job_a/job_b/job_serial/feeder shape to avoid colliding with
   sem10_box_basic.jil's job_a/job_b in the whole-corpus catalog.) Synthetic. */
insert_job: mutex_a
job_type: c
command: /opt/mutex_a.sh
machine: m1
condition: n(mutex_b)

insert_job: mutex_b
job_type: c
command: /opt/mutex_b.sh
machine: m1
condition: n(mutex_a) & s(mutex_feeder)

insert_job: mutex_serial
job_type: c
command: /opt/mutex_serial.sh
machine: m1
condition: n(mutex_serial)

insert_job: mutex_feeder
job_type: c
command: /opt/mutex_feeder.sh
machine: m1
date_conditions: 1
days_of_week: all
start_times: "06:00"
